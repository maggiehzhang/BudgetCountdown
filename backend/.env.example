PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_production_secret_here
PLAID_ENV=production
PLAID_ACCESS_TOKEN=
# Must exactly match a redirect URI registered in the Plaid Dashboard.
# After deploying, set this to https://<your-service>.onrender.com/oauth-redirect
PLAID_REDIRECT_URI=
PORT=3000
